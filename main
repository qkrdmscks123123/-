<body>
    <div class="container">
        <header>
            <h1>🏆 2024 체육대회</h1>
            <p>우리 학교 체육대회 시간표</p>
            <div class="stats">
                <div class="stat-item">
                    <div class="stat-number" id="totalEvents">0</div>
                    <div class="stat-label">전체 경기</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" id="filteredEvents">0</div>
                    <div class="stat-label">표시 경기</div>
                </div>
            </div>
        </header>

        <div class="filter-section">
            <div class="filter-title">🔍 반별 필터</div>
            <div class="filter-row">
                <div class="filter-group">
                    <label>학년:</label>
                    <select id="gradeSelect">
                        <option value="">전체 학년</option>
                        <option value="1">1학년</option>
                        <option value="2">2학년</option>
                        <option value="3">3학년</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>반:</label>
                    <select id="classSelect">
                        <option value="">전체 반</option>
                    </select>
                </div>
                <button class="reset-btn" onclick="resetFilter()">초기화</button>
            </div>
            <div class="current-filter" id="currentFilter">
                현재: <strong>전체 경기</strong> 표시 중
            </div>
        </div>

        <div class="schedule-section" id="scheduleContainer">
            <!-- 시간표가 여기에 렌더링됨 -->
        </div>
    </div>

    <script>
        // ========================================
        // 📌 여기서 데이터를 수정하세요!
        // ========================================
        
        const CONFIG = {
            // 학년별 반 개수 설정
            classesPerGrade: {
                1: 8,  // 1학년 8반까지
                2: 8,  // 2학년 8반까지
                3: 7   // 3학년 7반까지
            }
        };

        // 시간표 데이터
        // 참가팀 형식: "학년-반" (예: "1-3" = 1학년 3반)
        // 전체 학년 참가: "1-all", "2-all", "3-all"
        const scheduleData = [
            {
                time: "09:00 - 09:30",
                events: [
                    {
                        name: "개회식",
                        location: "운동장 본부석",
                        emoji: "🎊",
                        participants: ["1-all", "2-all", "3-all"]
                    }
                ]
            },
            {
                time: "09:30 - 10:30",
                events: [
                    {
                        name: "100m 달리기 예선",
                        location: "운동장 트랙",
                        emoji: "🏃",
                        participants: ["1-1", "1-2", "1-3", "1-4", "2-1", "2-2", "2-3", "2-4"]
                    },
                    {
                        name: "피구 예선 A조",
                        location: "체육관",
                        emoji: "🏐",
                        participants: ["3-1", "3-2", "3-3", "3-4"]
                    }
                ]
            },
            {
                time: "10:30 - 11:30",
                events: [
                    {
                        name: "100m 달리기 예선",
                        location: "운동장 트랙",
                        emoji: "🏃",
                        participants: ["1-5", "1-6", "1-7", "1-8", "2-5", "2-6", "2-7", "2-8"]
                    },
                    {
                        name: "피구 예선 B조",
                        location: "체육관",
                        emoji: "🏐",
                        participants: ["3-5", "3-6", "3-7"]
                    }
                ]
            },
            {
                time: "11:30 - 12:00",
                events: [
                    {
                        name: "줄다리기 1학년",
                        location: "운동장 중앙",
                        emoji: "🪢",
                        participants: ["1-all"]
                    }
                ]
            },
            {
                time: "12:00 - 13:00",
                events: [
                    {
                        name: "점심시간",
                        location: "각 반 교실",
                        emoji: "🍱",
                        participants: ["1-all", "2-all", "3-all"]
                    }
                ]
            },
            {
                time: "13:00 - 13:30",
                events: [
                    {
                        name: "줄다리기 2학년",
                        location: "운동장 중앙",
                        emoji: "🪢",
                        participants: ["2-all"]
                    }
                ]
            },
            {
                time: "13:30 - 14:00",
                events: [
                    {
                        name: "줄다리기 3학년",
                        location: "운동장 중앙",
                        emoji: "🪢",
                        participants: ["3-all"]
                    }
                ]
            },
            {
                time: "14:00 - 15:00",
                events: [
                    {
                        name: "계주 예선",
                        location: "운동장 트랙",
                        emoji: "🏃‍♂️",
                        participants: ["1-1", "1-2", "1-3", "1-4", "1-5", "1-6", "1-7", "1-8"]
                    },
                    {
                        name: "농구 3on3",
                        location: "농구장",
                        emoji: "🏀",
                        participants: ["2-1", "2-3", "2-5", "2-7", "3-1", "3-3", "3-5"]
                    }
                ]
            },
            {
                time: "15:00 - 16:00",
                events: [
                    {
                        name: "계주 결선",
                        location: "운동장 트랙",
                        emoji: "🏃‍♂️",
                        participants: ["1-all", "2-all"]
                    },
                    {
                        name: "축구 결승",
                        location: "운동장 축구장",
                        emoji: "⚽",
                        participants: ["3-2", "3-6"]
                    }
                ]
            },
            {
                time: "16:00 - 16:30",
                events: [
                    {
                        name: "폐회식 및 시상",
                        location: "운동장 본부석",
                        emoji: "🏅",
                        participants: ["1-all", "2-all", "3-all"]
                    }
                ]
            }
        ];

        // ========================================
        // 아래는 수정하지 않아도 됩니다
        // ========================================

        let selectedGrade = '';
        let selectedClass = '';

        // 반 선택 옵션 업데이트
        function updateClassOptions() {
            const classSelect = document.getElementById('classSelect');
            classSelect.innerHTML = '<option value="">전체 반</option>';
            
            if (selectedGrade) {
                const maxClass = CONFIG.classesPerGrade[selectedGrade] || 10;
                for (let i = 1; i <= maxClass; i++) {
                    const option = document.createElement('option');
                    option.value = i;
                    option.textContent = `${i}반`;
                    classSelect.appendChild(option);
                }
            }
        }

        // 참가팀이 필터에 매칭되는지 확인
        function isParticipantMatched(participant, grade, classNum) {
            const [pGrade, pClass] = participant.split('-');
            
            if (!grade) return true;
            if (pGrade !== grade) return false;
            if (!classNum) return true;
            if (pClass === 'all') return true;
            return pClass === classNum;
        }

        // 이벤트가 필터에 포함되는지 확인
        function isEventIncluded(event, grade, classNum) {
            return event.participants.some(p => isParticipantMatched(p, grade, classNum));
        }

        // 참가팀 표시 텍스트 생성
        function formatParticipant(participant) {
            const [grade, classNum] = participant.split('-');
            if (classNum === 'all') {
                return `${grade}학년 전체`;
            }
            return `${grade}-${classNum}`;
        }

        // 시간표 렌더링
        function renderSchedule() {
            const container = document.getElementById('scheduleContainer');
            const grade = selectedGrade;
            const classNum = selectedClass;
            
            let html = '';
            let totalEvents = 0;
            let filteredCount = 0;

            scheduleData.forEach(timeBlock => {
                const filteredEvents = timeBlock.events.filter(event => 
                    isEventIncluded(event, grade, classNum)
                );
                
                totalEvents += timeBlock.events.length;
                
                if (filteredEvents.length > 0) {
                    filteredCount += filteredEvents.length;
                    
                    html += `
                        <div class="time-block">
                            <div class="time-header">
                                <span class="time-icon">⏰</span>
                                ${timeBlock.time}
                            </div>
                            <div class="events-list">
                    `;
                    
                    filteredEvents.forEach(event => {
                        const hasSelectedClass = grade && classNum && 
                            event.participants.some(p => {
                                const [pGrade, pClass] = p.split('-');
                                return pGrade === grade && (pClass === classNum || pClass === 'all');
                            });
                        
                        html += `
                            <div class="event-card ${hasSelectedClass ? 'highlighted' : ''}">
                                <div class="event-emoji">${event.emoji}</div>
                                <div class="event-info">
                                    <div class="event-name">${event.name}</div>
                                    <div class="event-location">📍 ${event.location}</div>
                                    <div class="event-participants">
                                        ${event.participants.map(p => {
                                            const isMatched = grade && classNum && 
                                                (p === `${grade}-${classNum}` || p === `${grade}-all`);
                                            return `<span class="participant-tag ${isMatched ? 'matched' : ''}">${formatParticipant(p)}</span>`;
                                        }).join('')}
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                    
                    html += `
                            </div>
                        </div>
                    `;
                }
            });

            if (html === '') {
                html = `
                    <div class="no-events">
                        <div class="no-events-icon">😢</div>
                        <p>해당 조건에 맞는 경기가 없습니다.</p>
                    </div>
                `;
            }

            container.innerHTML = html;
            
            // 통계 업데이트
            document.getElementById('totalEvents').textContent = totalEvents;
            document.getElementById('filteredEvents').textContent = filteredCount;
            
            // 현재 필터 표시
            const filterText = document.getElementById('currentFilter');
            if (grade && classNum) {
                filterText.innerHTML = `현재: <strong>${grade}학년 ${classNum}반</strong> 관련 경기 표시 중`;
            } else if (grade) {
                filterText.innerHTML = `현재: <strong>${grade}학년 전체</strong> 관련 경기 표시 중`;
            } else {
                filterText.innerHTML = `현재: <strong>전체 경기</strong> 표시 중`;
            }
        }

        // 필터 초기화
        function resetFilter() {
            document.getElementById('gradeSelect').value = '';
            document.getElementById('classSelect').value = '';
            selectedGrade = '';
            selectedClass = '';
            updateClassOptions();
            renderSchedule();
        }

        // 이벤트 리스너
        document.getElementById('gradeSelect').addEventListener('change', (e) => {
            selectedGrade = e.target.value;
            selectedClass = '';
            document.getElementById('classSelect').value = '';
            updateClassOptions();
            renderSchedule();
        });

        document.getElementById('classSelect').addEventListener('change', (e) => {
            selectedClass = e.target.value;
            renderSchedule();
        });

        // 초기 렌더링
        renderSchedule();
    </script>
</body>
</html>
